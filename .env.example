# ---------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in the values.
# `.env.local` is gitignored. Never commit real credentials.
# On Vercel, add each of these under Project Settings -> Environment Variables.
# ---------------------------------------------------------------------------

# --- Supabase (Postgres only; Supabase Storage is not used) ----------------
# Project Settings -> API -> Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# Project Settings -> API -> Project API keys -> anon / public
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Project Settings -> API -> Project API keys -> service_role
# SERVER ONLY. Bypasses row-level security. Must never be exposed to the client,
# which is why it has no NEXT_PUBLIC_ prefix.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Cloudflare R2 ---------------------------------------------------------
# R2 dashboard URL, or Workers & Pages -> Overview -> Account ID
R2_ACCOUNT_ID=your-account-id
# R2 -> Manage R2 API Tokens -> Create API Token (Object Read & Write)
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
# The bucket photos are uploaded to
R2_BUCKET_NAME=dog-shelter-photos

# Public base URL for reading images back, no trailing slash.
# Either an R2 custom domain (recommended) or the r2.dev public bucket URL.
# This is public by design: it is baked into <img src> on the client.
NEXT_PUBLIC_R2_PUBLIC_URL=https://photos.your-domain.com
